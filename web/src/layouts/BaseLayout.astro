---
type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
};

const { title, description, canonicalPath = "/" } = Astro.props;
const siteUrl = "https://bowling-event.jp";
const canonical = new URL(canonicalPath, siteUrl).toString();
const siteName = "Bowling Calendar";
const japaneseSiteName = "全国プロチャレンジマッチ情報まとめ";
const siteStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: siteName,
      alternateName: japaneseSiteName,
      url: `${siteUrl}/`,
      description: "全国のプロボウリングチャレンジ、プロアマ、公式大会予定を整理するスケジュールサイトです。"
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: siteName,
      alternateName: japaneseSiteName,
      url: `${siteUrl}/`,
      inLanguage: "ja-JP",
      description: "プロ名、都道府県、ボウリング場名から全国のプロボウリングイベント予定を探せる検索サイトです。",
      publisher: {
        "@id": `${siteUrl}/#organization`
      },
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteUrl}/events/?q={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      inLanguage: "ja-JP",
      isPartOf: {
        "@id": `${siteUrl}/#website`
      },
      about: [
        "プロボウリング",
        "チャレンジマッチ",
        "プロアマ",
        "ボウリング場イベント"
      ]
    }
  ]
};
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="author" content={siteName} />
    <meta name="application-name" content={siteName} />
    <meta name="theme-color" content="#d9163a" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM summary" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={japaneseSiteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={JSON.stringify(siteStructuredData)} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">PRO<span>CHALLENGE</span></a>
      <nav aria-label="主要ナビゲーション">
        <a href="/events/">イベント一覧</a>
        <a href="/chains/">チェーン</a>
        <a href="/prefectures/">都道府県</a>
        <a href="/venues/">会場</a>
        <a href="/pros/">プロ</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>出典: 各ボウリング場公式サイト。参加前に必ず公式ページで最新情報を確認してください。</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --primary: #d9163a;
    --ink: #1f2933;
    --muted: #64707d;
    --line: #dde3ea;
    --surface: #ffffff;
    --wash: #f6f8fa;
    --link: #1167b1;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--surface);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.7;
  }

  a {
    color: var(--link);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px 32px;
    border-bottom: 2px solid var(--primary);
  }

  .brand {
    color: var(--primary);
    font-size: 24px;
    font-weight: 800;
    text-decoration: none;
  }

  .brand span {
    color: var(--ink);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 14px;
  }

  nav a {
    color: var(--ink);
    text-decoration: none;
  }

  main {
    padding: 32px;
  }

  .hero {
    max-width: 1080px;
    margin: 0 auto 28px;
  }

  h1 {
    margin: 0 0 12px;
    max-width: 16em;
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.2;
    overflow-wrap: anywhere;
    line-break: strict;
  }

  h2 {
    margin: 32px 0 12px;
    font-size: 22px;
  }

  .lead {
    max-width: 820px;
    color: var(--muted);
    font-size: 17px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .stat,
  .event,
  .link-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 16px;
  }

  .stat strong {
    display: block;
    color: var(--primary);
    font-size: 28px;
    line-height: 1.1;
  }

  .event-list {
    display: grid;
    gap: 10px;
  }

  .event {
    display: grid;
    gap: 4px;
  }

  .info-band {
    margin: 28px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
  }

  .info-band h2 {
    margin-top: 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
  }

  .info-grid h3 {
    margin: 0 0 6px;
    color: var(--primary);
    font-size: 17px;
  }

  .info-grid p {
    margin: 0;
    color: var(--muted);
  }

  .event time {
    color: var(--primary);
    font-weight: 800;
  }

  .event-title {
    color: var(--ink);
    font-size: 18px;
    font-weight: 700;
  }

  .meta {
    color: var(--muted);
    font-size: 14px;
  }

  .taxonomy {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    list-style: none;
  }

  .taxonomy a {
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 12px;
    text-decoration: none;
  }

  .taxonomy-label {
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 12px;
    background: var(--wash);
  }

  .prefecture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 10px;
  }

  .prefecture-card {
    display: grid;
    gap: 2px;
    min-height: 104px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    color: var(--ink);
    text-decoration: none;
  }

  .prefecture-card.is-active {
    border-color: color-mix(in srgb, var(--primary), white 30%);
    background: #fff8f8;
  }

  .prefecture-name {
    color: var(--primary);
    font-size: 18px;
    font-weight: 800;
  }

  .detail {
    max-width: 900px;
    margin: 0 auto;
  }

  .detail dl {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .detail dl div {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }

  .detail dt {
    color: var(--muted);
    font-weight: 700;
  }

  .detail dd {
    margin: 0;
  }

  .button-link {
    display: inline-block;
    margin-top: 18px;
    border: 1px solid var(--primary);
    border-radius: 6px;
    padding: 10px 16px;
    color: var(--primary);
    font-weight: 700;
    text-decoration: none;
  }

  .button-link:hover {
    background: var(--primary);
    color: #fff;
  }

  footer {
    border-top: 1px solid var(--line);
    background: var(--wash);
    color: var(--muted);
    padding: 24px 32px;
    font-size: 13px;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      padding: 14px 18px;
    }

    main {
      padding: 24px 18px;
    }

    .detail dl div {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
