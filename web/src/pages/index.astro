---
import EventList from "../components/EventList.astro";
import EventSearch from "../components/EventSearch.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { allEvents, allPrefectureNames, eventCountByPrefecture, pageSlug, siteFacets } from "../lib/events";

const latestEvents = allEvents.slice(0, 12);
const title = "全国プロボウリング チャレンジ/プロアマ情報 2026";
const description = "全国のプロボウリングチャレンジマッチやプロアマ公式予定を、日付・都道府県・会場・出演プロ名で探せる検索ポータルです。";
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://bowling-event.jp/#website",
      name: "全国プロチャレンジマッチ情報まとめ",
      url: "https://bowling-event.jp/",
      inLanguage: "ja",
      description
    },
    {
      "@type": "Dataset",
      "@id": "https://bowling-event.jp/#dataset",
      name: "全国プロボウリングチャレンジ/プロアマ開催予定データ",
      description: "各ボウリング場公式サイト、JPBA公式カレンダー等を参照して整理するプロボウラー参加イベントの開催予定データです。",
      temporalCoverage: "2026/2027",
      spatialCoverage: {
        "@type": "Country",
        name: "日本"
      }
    }
  ]
};
---
<BaseLayout title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section class="hero">
    <h1>全国プロボウリング チャレンジ/プロアマ情報 2026</h1>
    <p class="lead">
      全国のボウリング場で開催されるプロボウラー参加チャレンジマッチやプロアマ公式予定を、
      日付、都道府県、会場、出演プロ名で探せる公開スケジュールです。
    </p>
  </section>

  <section class="grid" aria-label="掲載データ概要">
    <div class="stat"><strong>{siteFacets.eventCount}</strong>掲載イベント</div>
    <div class="stat"><strong>{allPrefectureNames.length}</strong>都道府県</div>
    <div class="stat"><strong>{siteFacets.venues.length}</strong>会場</div>
    <div class="stat"><strong>{siteFacets.pros.length}</strong>プロ名</div>
  </section>

  <EventSearch events={allEvents} heading="プロ名・都道府県・ボウリング場名で検索" />

  <section>
    <h2>近日開催のチャレンジ/プロアマ予定</h2>
    <EventList events={latestEvents} />
  </section>

  <section>
    <h2>都道府県から探す</h2>
    <ul class="taxonomy">
      {allPrefectureNames.map((prefecture) => (
        <li><a href={`/prefectures/${pageSlug(prefecture)}/`}>{prefecture}</a></li>
      ))}
    </ul>
    <p class="meta">掲載中: {allPrefectureNames.filter((name) => eventCountByPrefecture(name) > 0).length}都道府県。未掲載エリアは公式情報の収集を順次強化しています。</p>
  </section>

  <section>
    <h2>チェーンから探す</h2>
    <ul class="taxonomy">
      {siteFacets.chains.map((chain) => (
        <li><a href={`/chains/${pageSlug(chain)}/`}>{chain}</a></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>出演プロから探す</h2>
    <ul class="taxonomy">
      {siteFacets.pros.slice(0, 40).map((pro) => (
        <li><a href={`/pros/${pageSlug(pro)}/`}>{pro}</a></li>
      ))}
    </ul>
  </section>
</BaseLayout>
