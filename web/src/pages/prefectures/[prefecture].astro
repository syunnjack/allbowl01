---
import EventList from "../../components/EventList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { byPrefecture, fromPageSlug, pageSlug, siteFacets } from "../../lib/events";

export function getStaticPaths() {
  return siteFacets.prefectures.map((prefecture) => ({
    params: { prefecture }
  }));
}

const prefecture = fromPageSlug(Astro.params.prefecture ?? "");
const events = byPrefecture(prefecture);
const title = `${prefecture}のプロボウリングチャレンジマッチ開催予定`;
const description = `${prefecture}で開催予定のプロボウリングチャレンジマッチを、日付・会場・出演プロ名で確認できます。`;
---
<BaseLayout title={title} description={description} canonicalPath={`/prefectures/${pageSlug(prefecture)}/`}>
  <section class="hero">
    <h1>{prefecture}のプロチャレンジ予定</h1>
    <p class="lead">{prefecture}のボウリング場で開催されるプロボウラー参加イベントを掲載しています。</p>
  </section>
  <EventList events={events} />
</BaseLayout>
